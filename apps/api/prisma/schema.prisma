generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum TipoPropiedad {
  CASA
  DEPARTAMENTO
  LOCAL
  TERRENO
  OFICINA
}

enum TipoPersona {
  PROPIETARIO
  INQUILINO
  INTERESADO
  GARANTE
}

enum TipoVinculo {
  ALQUILER
  VENTA
  ADMINISTRACION
}

enum Indice {
  ICL
  IPC
  UVA
}

enum TipoPago {
  ALQUILER
  EXPENSA
  SERVICIO
  HONORARIO
  DEPOSITO
  OTRO
}

enum Moneda {
  ARS
  USD
}

enum EstadoPago {
  PENDIENTE
  PAGADO
  VENCIDO
  MORA
  ANULADO
}

enum Canal {
  WHATSAPP
  EMAIL
  PRESENCIAL
}

enum TipoMensaje {
  ENTRANTE
  SALIENTE
  SISTEMA
}

enum EtapaConversacion {
  NUEVO           // primer contacto
  CONSULTANDO     // está preguntando, identificando qué busca
  INTERESADO      // mostró interés en una propiedad específica
  RECOPILANDO     // estamos pidiendo sus datos
  VISITA_PENDIENTE // quiere visitar, falta confirmar
  CLIENTE         // ya es cliente activo
  INACTIVO        // no respondió o cerró
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Propiedad {
  id               String            @id @default(cuid())
  direccion        String
  tipo             TipoPropiedad
  superficie       Float?
  enAlquiler       Boolean           @default(false)
  enVenta          Boolean           @default(false)
  administrada     Boolean           @default(false)
  alquilerBase     Float?
  indiceActual     Indice?
  valorVenta       Float?
  descripcion      String?
  notas            String?
  instagramPostId  String?
  imagenes              PropiedadImagen[]
  videos                PropiedadVideo[]
  vinculos              Vinculo[]
  pagos                 Pago[]
  inboxItems            InboxItem[]
  conversacionesInteres Conversacion[]
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
}

model PropiedadImagen {
  id          String    @id @default(cuid())
  propiedadId String
  url         String
  nombre      String
  orden       Int       @default(0)
  propiedad   Propiedad @relation(fields: [propiedadId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
}

model PropiedadVideo {
  id          String    @id @default(cuid())
  propiedadId String
  url         String
  nombre      String    // filename en disco
  titulo      String?   // título opcional
  orden       Int       @default(0)
  propiedad   Propiedad @relation(fields: [propiedadId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
}

model Persona {
  id         String      @id @default(cuid())
  nombre     String
  apellido   String
  dni        String?     @unique
  whatsapp   String?
  email      String?
  tipo       TipoPersona
  notas      String?
  vinculos       Vinculo[]
  pagos          Pago[]
  inboxItems     InboxItem[]
  conversaciones Conversacion[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Vinculo {
  id                   String      @id @default(cuid())
  propiedadId          String
  personaId            String
  tipo                 TipoVinculo
  fechaInicio          DateTime
  fechaFin             DateTime?
  alquilerInicial      Float?
  alquilerActual       Float?
  indice               Indice?
  periodicidad         Int         @default(3)
  proximaActualizacion DateTime?
  activo               Boolean     @default(true)
  notas                String?
  propiedad            Propiedad   @relation(fields: [propiedadId], references: [id])
  persona              Persona     @relation(fields: [personaId], references: [id])
  pagos                Pago[]
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
}

model Pago {
  id                 String     @id @default(cuid())
  tipo               TipoPago
  concepto           String
  monto              Float
  moneda             Moneda     @default(ARS)
  periodo            String?
  estado             EstadoPago @default(PENDIENTE)
  fechaVencimiento   DateTime
  fechaPago          DateTime?
  comprobanteEnviado Boolean    @default(false)
  propiedadId        String?
  personaId          String?
  vinculoId          String?
  propiedad          Propiedad? @relation(fields: [propiedadId], references: [id])
  persona            Persona?   @relation(fields: [personaId], references: [id])
  vinculo            Vinculo?   @relation(fields: [vinculoId], references: [id])
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
}

model Conversacion {
  id                  String              @id @default(cuid())
  numero              String              @unique
  personaId           String?
  etapa               EtapaConversacion   @default(NUEVO)
  tipoInteres         String?             // ALQUILER | VENTA | null
  propiedadInteresId  String?
  nombreCapturado     String?
  presupuesto         Float?
  notas               String?
  ultimoMensaje       DateTime            @default(now())
  persona             Persona?            @relation(fields: [personaId], references: [id])
  propiedadInteres    Propiedad?          @relation(fields: [propiedadInteresId], references: [id])
  mensajes            InboxItem[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
}

model InboxItem {
  id               String        @id @default(cuid())
  canal            Canal
  mensaje          String
  tipo             TipoMensaje
  leido            Boolean       @default(false)
  numero           String?
  conversacionId   String?
  propiedadId      String?
  personaId        String?
  conversacion     Conversacion? @relation(fields: [conversacionId], references: [id])
  propiedad        Propiedad?    @relation(fields: [propiedadId], references: [id])
  persona          Persona?      @relation(fields: [personaId], references: [id])
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model Usuario {
  id        String   @id @default(cuid())
  nombre    String
  email     String   @unique
  password  String
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
